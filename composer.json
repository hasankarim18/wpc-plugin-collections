{
  "name": "hasan/wp-plugin-collections",
  "autoload": {
    "psr-4": {
      "Hasan\\WpPluginCollections\\": "src/"
    }
  },
  "authors": [
    {
      "name": "hasankarim18",
      "email": "hallysust@gmail.com"
    }
  ],
  "scripts": {
    "analyse": "phpstan analyse",
    "make-pot": "wp i18n make-pot . languages/wp-plugin-collections.pot --include=src",
    "lint": "phpcs"
  },
  "require": {
    "php": ">=7.2"
  },
  "require-dev": {
    "php-stubs/wordpress-stubs": "^6.8",
    "php-stubs/woocommerce-stubs": "^10.6",
    "php-stubs/acf-pro-stubs": "^6.5",
    "arifpavel/elementor-stubs": "3.1.4.1",
    "phpstan/phpstan": "^1.11",
    "squizlabs/php_codesniffer": "^3.9",
    "phpcompatibility/php-compatibility": "^9.3",
    "php-stubs/woocommerce-subscriptions-stubs": "^8.4"
  },
  "config": {
    "platform": {
      "php": "8.0.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
